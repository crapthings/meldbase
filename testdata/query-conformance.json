{
  "version": 1,
  "cases": [
    {
      "name": "compound-range-or-sort-limit",
      "documents": [
        {"t":"object","v":[["_id",{"t":"string","v":"a"}],["age",{"t":"number","v":17}],["profile",{"t":"object","v":[["city",{"t":"string","v":"Shanghai"}]]}],["tags",{"t":"array","v":[{"t":"string","v":"new"}]}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"b"}],["age",{"t":"number","v":24}],["profile",{"t":"object","v":[["city",{"t":"string","v":"Hangzhou"}]]}],["tags",{"t":"array","v":[{"t":"string","v":"active"},{"t":"string","v":"new"}]}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"c"}],["age",{"t":"number","v":30}],["profile",{"t":"object","v":[["city",{"t":"string","v":"Shanghai"}]]}],["tags",{"t":"array","v":[]}]]}
      ],
      "query": {"version":1,"where":{"op":"and","args":[{"op":"compare","cmp":"gte","path":"age","value":{"t":"number","v":18}},{"op":"or","args":[{"op":"compare","cmp":"eq","path":"profile.city","value":{"t":"string","v":"Shanghai"}},{"op":"compare","cmp":"eq","path":"tags","value":{"t":"string","v":"active"}}]}]},"sort":[{"path":"age","direction":-1}],"limit":2},
      "expectedIds": ["c", "b"]
    },
    {
      "name": "missing-is-distinct-from-null",
      "documents": [
        {"t":"object","v":[["_id",{"t":"string","v":"a"}],["x",{"t":"null"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"b"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"c"}],["x",{"t":"array","v":[{"t":"number","v":1},{"t":"number","v":2}]}]]}
      ],
      "query": {"version":1,"where":{"op":"exists","path":"x","value":false}},
      "expectedIds": ["b"]
    },
    {
      "name": "int64-remains-exact-across-wire",
      "documents": [
        {"t":"object","v":[["_id",{"t":"string","v":"a"}],["n",{"t":"int64","v":"9007199254740993"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"b"}],["n",{"t":"number","v":10}]]}
      ],
      "query": {"version":1,"where":{"op":"compare","cmp":"gt","path":"n","value":{"t":"number","v":9007199254740992}}},
      "expectedIds": ["a"]
    },
    {
      "name": "utf8-byte-order-is-shared-by-range-filters",
      "documents": [
        {"t":"object","v":[["_id",{"t":"string","v":"non-bmp"}],["x",{"t":"string","v":"𐀀"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"bmp"}],["x",{"t":"string","v":""}]]}
      ],
      "query": {"version":1,"where":{"op":"compare","cmp":"gt","path":"x","value":{"t":"string","v":""}}},
      "expectedIds": ["non-bmp"]
    },
    {
      "name": "mixed-value-sort-has-one-transitive-order",
      "documents": [
        {"t":"object","v":[["_id",{"t":"string","v":"string-z"}],["value",{"t":"string","v":"z"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"number"}],["value",{"t":"number","v":0}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"string-a"}],["value",{"t":"string","v":"a"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"null"}],["value",{"t":"null"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"boolean"}],["value",{"t":"bool","v":true}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"time"}],["value",{"t":"date","v":"1970-01-01T00:00:00.000Z"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"id-earlier"}],["value",{"t":"id","v":"00000000000000000000000000000001"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"id-later"}],["value",{"t":"id","v":"00000000000000000000000000000002"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"binary"}],["value",{"t":"binary","v":"AQ=="}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"array"}],["value",{"t":"array","v":[]}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"object"}],["value",{"t":"object","v":[]}]]}
      ],
      "query": {"version":1,"where":{"op":"true"},"sort":[{"path":"value","direction":1}]},
      "expectedIds": ["null","boolean","number","string-a","string-z","time","id-earlier","id-later","binary","array","object"]
    },
    {
      "name": "generic-document-id-value-is-distinct-from-string",
      "documents": [
        {"t":"object","v":[["_id",{"t":"string","v":"generic-id"}],["value",{"t":"id","v":"00000000000000000000000000000001"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"plain-string"}],["value",{"t":"string","v":"00000000000000000000000000000001"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"other-id"}],["value",{"t":"id","v":"00000000000000000000000000000002"}]]}
      ],
      "query": {"version":1,"where":{"op":"compare","cmp":"eq","path":"value","value":{"t":"id","v":"00000000000000000000000000000001"}}},
      "expectedIds": ["generic-id"]
    },
    {
      "name": "array-size-distinguishes-empty-nonarray-and-missing",
      "documents": [
        {"t":"object","v":[["_id",{"t":"string","v":"empty"}],["items",{"t":"array","v":[]}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"two"}],["items",{"t":"array","v":[{"t":"null"},{"t":"number","v":2}]}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"object"}],["items",{"t":"object","v":[]}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"missing"}]]}
      ],
      "query": {"version":1,"where":{"op":"size","path":"items","size":0}},
      "expectedIds": ["empty"]
    },
    {
      "name": "type-union-is-exact-and-excludes-missing",
      "documents": [
        {"t":"object","v":[["_id",{"t":"string","v":"null"}],["value",{"t":"null"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"int64"}],["value",{"t":"int64","v":"1"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"float64"}],["value",{"t":"number","v":1}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"string"}],["value",{"t":"string","v":"1"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"array"}],["value",{"t":"array","v":[]}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"object"}],["value",{"t":"object","v":[]}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"missing"}]]}
      ],
      "query": {"version":1,"where":{"op":"type","path":"value","types":["array","int64","float64","int64"]}},
      "expectedIds": ["int64","float64","array"]
    },
    {
      "name": "size-and-type-compose-with-or-and-not",
      "documents": [
        {"t":"object","v":[["_id",{"t":"string","v":"empty"}],["items",{"t":"array","v":[]}],["value",{"t":"number","v":1}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"int64"}],["items",{"t":"array","v":[{"t":"null"}]}],["value",{"t":"int64","v":"1"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"float64"}],["items",{"t":"array","v":[{"t":"null"}]}],["value",{"t":"number","v":1}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"missing"}]]}
      ],
      "query": {"version":1,"where":{"op":"or","args":[{"op":"size","path":"items","size":0},{"op":"not","arg":{"op":"type","path":"value","types":["float64"]}}]}},
      "expectedIds": ["empty","int64","missing"]
    },
    {
      "name": "all-requires-every-deduplicated-array-value",
      "documents": [
        {"t":"object","v":[["_id",{"t":"string","v":"all"}],["tags",{"t":"array","v":[{"t":"string","v":"one"},{"t":"string","v":"two"},{"t":"object","v":[["x",{"t":"number","v":1}]]}]}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"pair"}],["tags",{"t":"array","v":[{"t":"string","v":"one"},{"t":"string","v":"two"}]}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"missing"}],["tags",{"t":"array","v":[{"t":"string","v":"one"}]}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"scalar"}],["tags",{"t":"string","v":"one"}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"absent"}]]}
      ],
      "query": {"version":1,"where":{"op":"all","path":"tags","values":[{"t":"string","v":"one"},{"t":"string","v":"two"},{"t":"string","v":"one"}]}},
      "expectedIds": ["all","pair"]
    },
    {
      "name": "elem-match-object-conditions-share-one-array-element",
      "documents": [
        {"t":"object","v":[["_id",{"t":"string","v":"split"}],["parts",{"t":"array","v":[{"t":"object","v":[["kind",{"t":"string","v":"a"}],["qty",{"t":"number","v":1}]]},{"t":"object","v":[["kind",{"t":"string","v":"b"}],["qty",{"t":"number","v":5}]]}]}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"same"}],["parts",{"t":"array","v":[{"t":"object","v":[["kind",{"t":"string","v":"a"}],["qty",{"t":"number","v":5}]]}]}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"scalar"}],["parts",{"t":"string","v":"not-array"}]]}
      ],
      "query": {"version":1,"where":{"op":"elem_match","path":"parts","mode":"object","arg":{"op":"and","args":[{"op":"compare","cmp":"eq","path":"kind","value":{"t":"string","v":"a"}},{"op":"compare","cmp":"gte","path":"qty","value":{"t":"number","v":5}}]}}},
      "expectedIds": ["same"]
    }
  ]
}
