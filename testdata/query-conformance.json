        {"t":"object","v":[["_id",{"t":"string","v":"b"}],["age",{"t":"number","v":24}],["profile",{"t":"object","v":[["city",{"t":"string","v":"Hangzhou"}]]}],["tags",{"t":"array","v":[{"t":"string","v":"active"},{"t":"string","v":"new"}]}]]},
        {"t":"object","v":[["_id",{"t":"string","v":"c"}],["age",{"t":"number","v":30}],["profile",{"t":"object","v":[["city",{"t":"string","v":"Shanghai"}]]}],["tags",{"t":"array","v":[]}]]}
