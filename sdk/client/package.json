{
  "name": "@meldbase/client",
  "version": "0.1.0-alpha.12",
  "description": "Isomorphic reactive query client for Meldbase",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crapthings/meldbase.git",
    "directory": "sdk/client"
  },
  "homepage": "https://github.com/crapthings/meldbase#readme",
  "bugs": "https://github.com/crapthings/meldbase/issues",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./local": {
      "types": "./dist/local.d.ts",
      "default": "./dist/local.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "default": "./dist/internal.js"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/internal.js",
    "dist/internal.d.ts",
    "dist/cursor.js",
    "dist/cursor.d.ts",
    "dist/local.js",
    "dist/local.d.ts",
    "dist/mutation.js",
    "dist/mutation.d.ts",
    "dist/observer.js",
    "dist/observer.d.ts",
    "dist/protocol.js",
    "dist/protocol.d.ts",
    "dist/query.js",
    "dist/query.d.ts",
    "dist/remote.js",
    "dist/remote.d.ts",
    "dist/remote/**",
    "dist/safe-value.js",
    "dist/safe-value.d.ts",
    "dist/types.js",
    "dist/types.d.ts",
    "dist/wire.js",
    "dist/wire.d.ts"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm run build",
    "test": "pnpm run build && node --test dist/**/*.test.js",
    "coverage": "pnpm run build && c8 --all --include \"dist/**/*.js\" --exclude \"dist/**/*.test.js\" --exclude \"dist/**/*.typecheck.js\" --check-coverage --statements 80 --branches 75 --functions 80 --lines 80 node --test dist/**/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
