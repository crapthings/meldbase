{
  "name": "@meldbase/react",
  "version": "0.1.0-alpha.12",
  "description": "Thin React adapter for Meldbase live queries",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crapthings/meldbase.git",
    "directory": "sdk/react"
  },
  "homepage": "https://github.com/crapthings/meldbase#readme",
  "bugs": "https://github.com/crapthings/meldbase/issues",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm --filter @meldbase/client run build && pnpm run build",
    "test": "pnpm run build && node --test dist/*.test.js",
    "coverage": "pnpm run build && c8 --all --include \"dist/**/*.js\" --exclude \"dist/**/*.test.js\" --check-coverage --statements 80 --branches 75 --functions 80 --lines 80 node --test dist/*.test.js"
  },
  "peerDependencies": {
    "@meldbase/client": "workspace:*",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@meldbase/client": "workspace:*",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^27.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
