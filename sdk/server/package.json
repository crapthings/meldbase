{
  "name": "@meldbase/server",
  "version": "0.1.0-alpha.11",
  "description": "Trusted Node.js method and data-only read-policy worker SDK for Meldbase",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crapthings/meldbase.git",
    "directory": "sdk/server"
  },
  "homepage": "https://github.com/crapthings/meldbase#readme",
  "bugs": "https://github.com/crapthings/meldbase/issues",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/definitions.js",
    "dist/definitions.d.ts",
    "dist/errors.js",
    "dist/errors.d.ts",
    "dist/index.js",
    "dist/index.d.ts",
    "dist/protocol.js",
    "dist/protocol.d.ts",
    "dist/shared.js",
    "dist/shared.d.ts",
    "dist/transaction.js",
    "dist/transaction.d.ts",
    "dist/types.js",
    "dist/types.d.ts",
    "dist/worker.js",
    "dist/worker.d.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@meldbase/client": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=20"
  }
}
