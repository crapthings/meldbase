#!/bin/sh
set -eu

# This launcher runs the current JWT/collection-policy server path. Keep the
# public listener on loopback until an application-owned TLS proxy is configured.
: "${MELDBASE_BIN:=/usr/local/bin/meld}"
: "${MELDBASE_DB:=/var/lib/meldbase/data/app.meld}"
: "${MELDBASE_ADDR:=127.0.0.1:8080}"
: "${MELDBASE_ADMIN_ADDR:=127.0.0.1:9091}"
: "${MELDBASE_ADMIN_TOKEN:=}"
: "${MELDBASE_JWT_HS256_SECRET_FILE:=}"
: "${MELDBASE_JWT_ISSUER:=}"
: "${MELDBASE_JWT_AUDIENCE:=}"
: "${MELDBASE_ACCESS_POLICY_FILE:=}"
: "${MELDBASE_WORKSPACE_COLLECTIONS:=}"
: "${MELDBASE_WORKSPACE_FIELD:=workspaceId}"

case "$MELDBASE_ADDR" in
  127.*:*|'[::1]':*) ;;
  *)
    printf '%s\n' 'MELDBASE_ADDR must be a loopback address; place TLS at the application boundary' >&2
    exit 2
    ;;
esac
case "$MELDBASE_ADMIN_ADDR" in
  127.*:*|'[::1]':*) ;;
  *)
    printf '%s\n' 'MELDBASE_ADMIN_ADDR must be a loopback address' >&2
    exit 2
    ;;
esac
if [ "${#MELDBASE_ADMIN_TOKEN}" -lt 32 ] || [ "$MELDBASE_ADMIN_TOKEN" = CHANGE_ME_GENERATE_A_RANDOM_TOKEN ]; then
  printf '%s\n' 'MELDBASE_ADMIN_TOKEN must be a unique random token of at least 32 bytes' >&2
  exit 2
fi
if [ -z "$MELDBASE_JWT_HS256_SECRET_FILE" ] || [ ! -r "$MELDBASE_JWT_HS256_SECRET_FILE" ]; then
  printf '%s\n' 'MELDBASE_JWT_HS256_SECRET_FILE must name a readable 32+ byte secret file' >&2
  exit 2
fi
if [ -z "$MELDBASE_JWT_ISSUER" ] || [ -z "$MELDBASE_JWT_AUDIENCE" ]; then
  printf '%s\n' 'MELDBASE_JWT_ISSUER and MELDBASE_JWT_AUDIENCE are required' >&2
  exit 2
fi
if [ -n "$MELDBASE_ACCESS_POLICY_FILE" ] && [ -n "$MELDBASE_WORKSPACE_COLLECTIONS" ]; then
  printf '%s\n' 'MELDBASE_ACCESS_POLICY_FILE and MELDBASE_WORKSPACE_COLLECTIONS are mutually exclusive' >&2
  exit 2
fi
if [ -n "$MELDBASE_ACCESS_POLICY_FILE" ]; then
  if [ ! -r "$MELDBASE_ACCESS_POLICY_FILE" ]; then
    printf '%s\n' 'MELDBASE_ACCESS_POLICY_FILE must name a readable manifest' >&2
    exit 2
  fi
  set -- --access-policy-file "$MELDBASE_ACCESS_POLICY_FILE"
elif [ -n "$MELDBASE_WORKSPACE_COLLECTIONS" ]; then
  set -- --workspace-collections "$MELDBASE_WORKSPACE_COLLECTIONS" --workspace-field "$MELDBASE_WORKSPACE_FIELD"
else
  printf '%s\n' 'MELDBASE_ACCESS_POLICY_FILE or MELDBASE_WORKSPACE_COLLECTIONS is required' >&2
  exit 2
fi

exec "$MELDBASE_BIN" serve \
  --db "$MELDBASE_DB" \
  --addr "$MELDBASE_ADDR" \
  --jwt-hs256-secret-file "$MELDBASE_JWT_HS256_SECRET_FILE" \
  --jwt-issuer "$MELDBASE_JWT_ISSUER" \
  --jwt-audience "$MELDBASE_JWT_AUDIENCE" \
  "$@" \
  --admin-addr "$MELDBASE_ADMIN_ADDR" \
  --admin-diagnostics \
  --admin-metrics
