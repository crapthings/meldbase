# Copy to /etc/meldbase/meldbase.env, set ownership to root:meldbase and mode
# 0640. The JWT secret file must be readable by the meldbase service account,
# mode 0640 and owned by root:meldbase.
MELDBASE_BIN=/usr/local/bin/meld
MELDBASE_DB=/var/lib/meldbase/data/app.meld
MELDBASE_ADDR=127.0.0.1:8080
MELDBASE_ADMIN_ADDR=127.0.0.1:9091
MELDBASE_ADMIN_TOKEN=CHANGE_ME_GENERATE_A_RANDOM_TOKEN
MELDBASE_JWT_HS256_SECRET_FILE=/etc/meldbase/jwt-hs256.secret
MELDBASE_JWT_ISSUER=https://identity.example/
MELDBASE_JWT_AUDIENCE=meldbase-api
MELDBASE_ACCESS_POLICY_FILE=/etc/meldbase/access-policy.json
# These values define the browser boundary at the TLS proxy. Use exact HTTP(S)
# origins for API requests and matching scheme+host patterns for WebSocket
# upgrades. Keep the defaults for a loopback-only local application.
MELDBASE_PUBLIC_REALTIME_URL=
MELDBASE_HTTP_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://[::1]:5173
MELDBASE_REALTIME_ORIGIN_PATTERNS=localhost:*,127.0.0.1:*,[[]::1]:*
